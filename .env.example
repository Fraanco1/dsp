# NASA Earthdata — https://urs.earthdata.nasa.gov (free)
# Used for: ASF SAOCOM download + Copernicus DEM via earthaccess
EARTHDATA_USERNAME=your_username
EARTHDATA_PASSWORD=your_password

# Copernicus Data Space OAuth — https://shapps.dataspace.copernicus.eu/dashboard/
# Create OAuth client under "User Settings > OAuth clients"
# Used for: Sentinel-2 access via sentinelhub
SH_CLIENT_ID=your_client_id
SH_CLIENT_SECRET=your_client_secret

# CONAE direct catalog — https://catalogos.conae.gov.ar (optional)
# ASF is preferred for programmatic SAOCOM access
CONAE_USER=your_username
CONAE_PASSWORD=your_password
